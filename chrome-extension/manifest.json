{
  "manifest_version": 3,
  "name": "SongSurf Clip",
  "version": "1.0.0",
  "description": "Ajoute les chansons/albums/playlists YouTube Music directement dans la queue SongSurf.",

  "permissions": [
    "storage",
    "alarms"
  ],

  "host_permissions": [
    "https://music.youtube.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "SongSurf Clip"
  },

  "options_page": "options/options.html",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
