# SongSurf — exemple de configuration
# Copier vers .env puis lancer : make secrets
# Le matériel de clés (mots de passe, clés hex) va dans .secrets — généré par make secrets.

# ── Déploiement ────────────────────────────────────────────────────────────
# local = bridge Docker, ports publiés en localhost (développement)
# nas   = network_mode host, réseau direct NAS (production)
DEPLOY_TARGET=local
WATCHER_PORT=8080

# ── Routage interne (ne pas modifier) ─────────────────────────────────────
TARGET_URL=http://songsurf:8081
TARGET_URL_NAS=http://localhost:8081

# ── Limites téléchargement ────────────────────────────────────────────────
DAILY_DOWNLOAD_LIMIT=50
MAX_DURATION_SECONDS=9000

# ── Arrêt automatique (inactivité) ────────────────────────────────────────
INACTIVITY_WARN_TIMEOUT=3600
INACTIVITY_GRACE_TIMEOUT=900

# ── Mode dev ─────────────────────────────────────────────────────────────
# true = bypass complet de l'auth JWT — JAMAIS en production
DEV_MODE=false

# ── Auth JWT — Phase 3 (rev0auth) ─────────────────────────────────────────
# Renseigner quand rev0auth est en ligne. Vide = désactive l'intégration JWT.
AUTH_SERVICE_LOGIN_URL=

# ── Adresses donation (optionnel) ─────────────────────────────────────────
DONATION_BTC=
DONATION_ETH=
DONATION_SOL=
DONATION_XMR=
