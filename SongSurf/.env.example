# SongSurf — configuration example
# Copy to .env then run: make secrets
# Key material (passwords, hex keys) goes in .secrets — generated by make secrets.

# ── Deployment ─────────────────────────────────────────────────────────────
# local = bridge network, localhost ports (dev)
# nas   = host network, production NAS
DEPLOY_TARGET=local
WATCHER_PORT=8080

# ── Internal routing ────────────────────────────────────────────────────────
# local mode: watcher reaches songsurf via Docker DNS
TARGET_URL=http://songsurf:8081
# nas mode: both on host network, use localhost
TARGET_URL_NAS=http://localhost:8081

# ── Inactivity shutdown ─────────────────────────────────────────────────────
INACTIVITY_WARN_TIMEOUT=3600
INACTIVITY_GRACE_TIMEOUT=900

# ── Dev mode ─────────────────────────────────────────────────────────────────
# true = bypass JWT auth entirely — NEVER use in production
DEV_MODE=false

# ── Auth service — Phase 3 (rev0auth) ───────────────────────────────────────
# Set when rev0auth is online. Leave empty to disable JWT auth (blocks all logins).
AUTH_SERVICE_LOGIN_URL=

# ── Donation addresses (optional) ────────────────────────────────────────────
DONATION_BTC=
DONATION_ETH=
DONATION_SOL=
DONATION_XMR=
