# .dockerignore - Fichiers à exclure de l'image Docker

# Python
__pycache__/
*.py[cod]
*.so
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# Virtual Environment
venv/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Git
.git/
.gitignore

# Documentation
*.md
!README.md

# Données (ne pas inclure dans l'image)
data/
temp/
music/

# Frontend — exclude dev artifacts and local build output
# Stage 1 of the Dockerfile does a fresh npm build inside the container.
# The local frontend/build/ is not used and would bloat the build context.
frontend/node_modules/
frontend/.svelte-kit/
frontend/build/

# Docker
.dockerignore
Dockerfile*
docker-compose*.yml

# Configuration locale et secrets
.env
.env.*
.secrets
.env.example

# Tests
tests/
*.test.py

# Temporaires
*.tmp
*.temp
*.bak
