# .dockerignore - Fichiers à exclure de l'image Docker

# Python
__pycache__/
*.py[cod]
*.so
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# Virtual Environment
venv/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Git
.git/
.gitignore

# Documentation
*.md
!README.md

# Données (ne pas inclure dans l'image)
data/
temp/
music/

# Frontend — exclude dev artifacts, keep build output for multi-stage copy
frontend/node_modules/
frontend/.svelte-kit/
# frontend/build/ must NOT be excluded (used by Dockerfile stage 1 directly)

# Docker
.dockerignore
Dockerfile*
docker-compose*.yml

# Configuration locale et secrets
.env
.secrets
env.example

# Tests
tests/
*.test.py

# Temporaires
*.tmp
*.temp
*.bak
